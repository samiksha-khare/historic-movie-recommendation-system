<!DOCTYPE html>
<html lang="en">
<head>
    <title>Historic Milestones</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>

    <link rel="stylesheet" type="text/css" href="/public/css/style.css" />
    <link rel="stylesheet" type="text/css" href="/public/css/chat.css" />
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
</head>

<body>
    <!-- Hero Header -->
    <header class="site-header">
        <div class="header-content">
            <h1 id="welcome">Historic Milestones</h1>
            <p class="header-subtitle">Explore history through events, movies & AI-powered insights</p>
        </div>
    </header>

    <!-- Toolbar -->
    <div class="toolbar">
        <div class="toolbar-filters">
            <div class="filter-group">
                <label for="genre">Genre</label>
                <select id="genre">
                    <!-- Options added dynamically -->
                </select>
            </div>

            <div class="filter-group">
                <label for="region">Region</label>
                <select id="region">
                </select>
            </div>
        </div>

        <div class="toolbar-actions">
            <button type="button" class="btn-primary-action" data-toggle="modal" data-target="#showAddModal">
                + Add Event
            </button>

            <a href="https://nextflick-movie-recommender.streamlit.app/" target="_blank" class="btn-secondary-action" id="movieRecommendationButton">
                Movie Recommender
            </a>

            <button type="button" id="compareSelected" class="btn-compare" style="display:none;" onclick="compareSelectedEvents()">
                Compare Selected
            </button>
        </div>
    </div>

    <!-- Add Event Modal -->
    <div class="modal fade" id="showAddModal" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Add New Event</h4>
                </div>
                <div class="modal-body modal-form">
                    <div class="form-group">
                        <label for="addEventName">Event Name</label>
                        <input type="text" id="addEventName" name="eventName" placeholder="e.g. The Renaissance" required>
                    </div>
                    <div class="form-row">
                        <div class="form-group half">
                            <label for="addStartYear">Start Year</label>
                            <input type="text" id="addStartYear" name="startYear" placeholder="e.g. 1400" required>
                        </div>
                        <div class="form-group half">
                            <label for="addEndYear">End Year</label>
                            <input type="text" id="addEndYear" name="endYear" placeholder="e.g. 1600">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group half">
                            <label for="addRegion">Region</label>
                            <input type="text" id="addRegion" name="region" placeholder="e.g. Europe" required>
                        </div>
                        <div class="form-group half">
                            <label for="addGenre">Genre</label>
                            <input type="text" id="addGenre" name="genre" placeholder="e.g. Culture, Art">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="addDescription">Description</label>
                        <textarea id="addDescription" name="description" rows="3" placeholder="Describe the historical event..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-save" id="addNewEvent" data-dismiss="modal">Add Event</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Event Details Modal -->
    <div class="modal fade" id="eventModal" tabindex="-1" role="dialog" aria-labelledby="eventModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title" id="eventModalLabel">Event Details</h4>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="event-detail">
                        <label>Event Name</label>
                        <span id="event_name"></span>
                    </div>
                    <div class="event-detail-row">
                        <div class="event-detail half">
                            <label>Start Year</label>
                            <span id="event_start_year"></span>
                        </div>
                        <div class="event-detail half">
                            <label>End Year</label>
                            <span id="event_end_year"></span>
                        </div>
                    </div>
                    <div class="event-detail">
                        <label>Region</label>
                        <span id="event_region"></span>
                    </div>
                    <div class="event-detail">
                        <label>Description</label>
                        <span id="event_description"></span>
                    </div>
                    <div class="event-detail">
                        <label>Genres</label>
                        <span id="event_genres"></span>
                    </div>
                    <div class="event-detail">
                        <label>Recommended Movies</label>
                        <span id="event_movies"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-edit" id="edit_event" data-dismiss="modal" aria-label="Edit">Edit</button>
                    <button type="button" class="btn btn-delete" id="delete_event" data-dismiss="modal" aria-label="Delete">Delete</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Modal -->
    <div class="modal fade" id="editModal" role="dialog">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                    <h4 class="modal-title">Edit Event</h4>
                </div>
                <div class="modal-body modal-form">
                    <div class="form-group">
                        <label for="editEventName">Event Name</label>
                        <input type="text" id="editEventName" name="eventName" required>
                    </div>
                    <div class="form-row">
                        <div class="form-group half">
                            <label for="editStartYear">Start Year</label>
                            <input type="text" id="editStartYear" name="startYear" required>
                        </div>
                        <div class="form-group half">
                            <label for="editEndYear">End Year</label>
                            <input type="text" id="editEndYear" name="endYear">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="editRegion">Region</label>
                        <input type="text" id="editRegion" name="region" required>
                    </div>
                    <div class="form-group">
                        <label for="editDescription">Description</label>
                        <textarea id="editDescription" name="description" rows="3"></textarea>
                    </div>
                    <div class="form-group">
                        <label for="editGenres">Add Genres</label>
                        <input type="text" id="editGenres" name="genres" placeholder="Comma-separated genres">
                        <ul id="deleteGenres" class="genre-tag-list"></ul>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-cancel" data-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-save" id="save_button" data-dismiss="modal">Save Changes</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Events Table -->
    <div class="table-container">
        <table id="eventsTable">
            <thead>
                <tr>
                    <th class="th-compare">Compare</th>
                    <th class="th-sno">S.No</th>
                    <th class="th-name">Event Name</th>
                    <th class="th-year">Start Year</th>
                </tr>
            </thead>
            <tbody>
            <!-- Rows will be added here dynamically -->
            </tbody>
        </table>
    </div>

    <!-- Footer -->
    <footer class="site-footer">
        <p>Built by Samiksha Khare &middot; Powered by Kafka, TF-IDF & AI</p>
    </footer>

    <%- include('partials/chat_panel') %>
</body>

<!--<script src="/public/js/home_not_used.js"></script>-->
<script src="/public/js/event_handlers.js"></script>
<script src="/public/js/api_calls.js"></script>
<script src="/public/js/populate_ui.js"></script>
<script src="/public/js/chat.js"></script>
</html>
